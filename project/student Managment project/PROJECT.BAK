      scanf("%d",&ch);
	   switch(ch)
	   {
	     case 1: insert();
		      break;
	     case 2: showdata();
		     break;
	     case 3: update();
		     break;
	     case 4: del1();
		     break;
	     case 5: srch();
		     break;
	     case 0: break;
	   }
      }while(ch!=0);
}else{
